# ==========================================
# PYTHON
# ==========================================
# Bytecode files (compiled)
__pycache__/
*.py[cod]
*$py.class

# Distributions, packages, and installers
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/

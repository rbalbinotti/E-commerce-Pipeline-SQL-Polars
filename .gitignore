.installed.cfg
*.egg
MANIFEST

# Virtual Environments (VENV)
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Code profiling and test files (Pytest, Coverage)
.cache
.pytest_cache/
.coverage
.htmlcov/
.mypy_cache/
.ruff_cache/

# ==========================================
# JUPYTER NOTEBOOK
# ==========================================
# Hidden folders and Jupyter checkpoints
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# Local IPython profile files
.ipython/

# Checkpoint files generated by VS Code for Notebooks
*.ipynb_checkpoints

# (Optional) Uncomment the line below if you do NOT want to save chart/table outputs
# *.nbconvert.html

# ==========================================
# VISUAL STUDIO CODE (VS CODE)
# ==========================================
# Local workspace settings (optional, remove if you want to share recommended extensions)
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json

# VS Code temporary and history files
*.code-workspace
.history/

# ==========================================
# OPERATING SYSTEM AND DATA (General)
# ==========================================
# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# Windows system files
Thumbs.db
ehthumbs.db
Desktop.ini

# Environment variable files containing sensitive data/passwords
.env
.env.local
.env.*.local

# ==========================================
# UV (ASTRAL PACKAGE MANAGER)
# ==========================================
# Default virtual environment created by uv (.venv is already covered in the Python block)
.venv/

# Local uv cache (temporarily stored in the project if configured)
.uv/

# Temporary and lock files generated during synchronization
.uv-cache/

# ==========================================
# DATABASE
# ==========================================
mysql_db/
archive/
*.zip
sqlachemy_raw.ipynb
